PORT=5000
MONGO_URI=mongodb://localhost:27017/ai-career-copilot
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Anthropic Claude API (optional — rule-based fallback works without it)
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── Gmail OTP Setup ──────────────────────────────────────────────────────────
# Step 1: Make sure 2-Step Verification is ON for your Google account
#         → https://myaccount.google.com/security
#
# Step 2: Generate an App Password (NOT your normal Gmail password)
#         → https://myaccount.google.com/apppasswords
#         → App name: Career Copilot → click Create
#         → Copy the 16-char password shown (e.g. abcd efgh ijkl mnop)
#
# Step 3: Paste below — remove all spaces from the app password
#
EMAIL_USER=sapgandhi@gmail.com
EMAIL_PASS=abcdefghijklmnop
#
# If EMAIL_PASS is not set or still says 'your_gmail_app_password_16chars',
# the app runs in dev mode and prints the OTP to the backend terminal instead.
# ─────────────────────────────────────────────────────────────────────────────
